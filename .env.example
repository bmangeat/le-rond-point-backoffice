# ─── Base de données (Neon — MÊME base que le-rond-point) ─────────────────────
# Runtime app : connexion poolée (Neon -pooler / PgBouncer)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.neon.tech/DB?sslmode=require"
# Migrations / introspection : connexion directe (non poolée)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# ─── NextAuth v5 (Auth.js) ────────────────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET="change-me"
# En prod sur Vercel : NE PAS définir (auto-détecté via trustHost).
# En local uniquement :
# NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
AUTH_GOOGLE_ID="xxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxx"

# ─── App le-rond-point (cible des liens d'invitation) ─────────────────────────
# Base URL de l'app principale qui consomme les liens /invite/<token>.
# Sans slash final. Ex QA : https://le-rond-point-qa.vercel.app
APP_BASE_URL="https://le-rond-point-qa.vercel.app"

# ─── Web Push (broadcast) ─────────────────────────────────────────────────────
# ⚠️ MÊMES clés VAPID que le-rond-point, sinon les abonnements (créés côté app)
# rejettent les notifications. Copier depuis l'env de le-rond-point.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:contact@le-rond-point.app"
# Callback à autoriser dans Google Cloud :
#   http://localhost:3000/api/auth/callback/google
#   https://<env>.vercel.app/api/auth/callback/google
